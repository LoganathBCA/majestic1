# ===========================================================
# Majestic Sports — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — only commit this .env.example file.
# ===========================================================
# For Cloudflare Pages deployment:
# Go to → Project → Settings → Environment Variables
# and add every variable below (for both Production & Preview).
# ===========================================================

# ── Firebase ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Admin ────────────────────────────────────────────────────
VITE_ADMIN_UID=

# ── Cloudinary ───────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_UPLOAD_URL=

# ── WhatsApp ─────────────────────────────────────────────────
# Format: country code + number, no + or spaces (e.g. 919876543210)
VITE_WHATSAPP_NUMBER=
